# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== 图谱后端 =====
# zep = Zep Cloud / 自托管 zep-cloud API（需 ZEP_API_KEY）
# local = 本地 Neo4j + Qdrant（方案 B，无 Zep 额度；需 docker compose -f docker-compose.local.yml up -d）
GRAPH_BACKEND=zep

# ===== ZEP记忆图谱配置（GRAPH_BACKEND=zep）=====
# 云端：每月免费额度可支撑简单使用 https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here
# 自托管（可选）：服务根地址，不要写 /api/v2（zep-cloud SDK 会自动拼接）
# 例：本机 OpenZep / Zep CE 默认端口 → http://127.0.0.1:8000
# MiroFish 跑在 Docker 内、Zep 在宿主机时 → http://host.docker.internal:8000
# ZEP_API_URL=http://127.0.0.1:8000
# 若使用 OpenZep 的 install_mirofish.sh，也可只写 ZEP_BASE_URL（会与 ZEP_API_URL 等价）
# ZEP_BASE_URL=http://127.0.0.1:8000

# ===== 本地图谱（GRAPH_BACKEND=local）=====
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=mirofish_local_pwd
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION_CHUNKS=mirofish_chunks
# 需与 LLM 同兼容接口的 embedding 模型，例如 OpenAI text-embedding-3-small 或百炼 text-embedding-v4
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here